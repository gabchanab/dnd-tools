  {
    "id": "planar_refugee",
    "name": "Planar Refugee",
    "source": "Homebrew",
    "homebrew": true,
    "benefits": [
      {
        "name": "Ability Score Increases",
        "desc": "+2 to one ability score of your choice, +1 to another.",
        "type": "ability_score"
      },
      {
        "name": "Skill Proficiencies",
        "desc": "Arcana and Survival.",
        "type": "skill_proficiency"
      },
      {
        "name": "Tool Proficiency",
        "desc": "Cartographer's Tools.",
        "type": "tool_proficiency"
      },
      {
        "name": "Languages",
        "desc": "One of your choice.",
        "type": "language"
      },
      {
        "name": "Equipment",
        "desc": "Traveler's clothes, a fragment of a star map from your home plane, and 50 gp.",
        "type": "equipment"
      },
      {
        "name": "Origin Feat",
        "desc": "Magic Initiate (Druid).",
        "type": "feat"
      },
      {
        "name": "Planar Instinct",
        "desc": "You were displaced from your home plane by a catastrophic event and found yourself stranded on the Material Plane with nothing but your wits. You have advantage on Intelligence (Arcana) checks made to recall information about other planes of existence.",
        "type": "trait"
      }
    ]
  },
